VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Публичный DSN Sentry (не секрет) — как и остальные VITE_* переменные,
# в Cloudflare Pages должен быть добавлен ЯВНО в Build command,
# Dashboard-переменные к сборке не долетают (см. AGENT_LOG.md).
VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
